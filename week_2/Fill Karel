from karel.stanfordkarel import *

def main():
   
 
    while left_is_clear():
        if front_is_clear():
            fill()
        if front_is_blocked():
           come_back()
        if left_is_blocked():
            fill() 

#cover one row facing right
def fill():
    
    put_beeper()
    while front_is_clear():
        move()
        put_beeper()

#come back
def come_back():
    if front_is_blocked():
        turn_around()
        while front_is_clear():
            move()
        turn_right()
        move()
        turn_right()

#turn around
def turn_around():
    for i in range(2):
        turn_left()

def turn_right():
    for i in range(3):
        turn_left()

# There is no need to edit code beyond this point
if __name__ == '__main__':
    main()
