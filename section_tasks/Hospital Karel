from karel.stanfordkarel import *

def main():

    while front_is_clear():
        if beepers_present():
            build_hospital()
        if front_is_clear():
            move()
        
def build_hospital():
    build_one_column()
    build_second_column()
    turn_left()

def build_one_column():
    turn_left()
    for i in range(2):
        move()
        put_beeper()

def build_second_column():
    turn_right()
    move()
    turn_right()
    for i in range(2):
        put_beeper()
        move()
    put_beeper()

def turn_right():
    for i in range(3):
        turn_left()


if __name__ == '__main__':
    main()
